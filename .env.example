# MQTT broker URL for MTConnect device streams
MQTT_BROKER=mqtts://mqtt.russwaddell.com:8883

# MTConnect device UUIDs (must match MQTT topic device names)
OKUMA_DEVICE_UUID=OKUMA.123456
MAZAK_DEVICE_UUID=Mazak

# Port exposed to host for nginx reverse proxy
I3XAG_PORT=9000
I3XDB_PORT=8080
I3XMT_OKUMA_PORT=8081
I3XMT_MAZAK_PORT=8082
